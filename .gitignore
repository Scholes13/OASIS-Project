# Dependencies
/vendor/
/node_modules/

# Build artifacts
/public/build/
/public/hot

# Environment and runtime
/.env
/.env.*
!/.env.example
/storage/*.key

# Laravel generated files
/bootstrap/cache/*
!/bootstrap/cache/.gitignore
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore

# Test and tooling caches
/.phpunit.result.cache
/.phpunit.cache/
/coverage/

# IDE and OS files
/.idea/
/.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local git worktrees
/.worktrees/
/.superpowers/

# IDE helper files (auto-generated)
_ide_helper.php
_ide_helper_models.php
.phpstorm.meta.php

# Temporary fix/debug scripts
/fix*.cjs
/fix*.js
/fix*.sh
/fix*.py
/check_*.php
/clear_*.php
/update_*.php
/build_*.js
/make_*.cjs
/manual-fix*
/replace-all*
/rewrite*
/run-grid*

# QA scratch scripts and artifacts
tests/playwright-*.mjs
tests/browser-qa-*.mjs
tests/screenshots/
tests/e2e/screenshots/
test-results/
tmp-*
tmp_*

# EnvSitter local state
.envsitter/
