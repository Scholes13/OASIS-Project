<body>
    <!-- PDF Download Instruction (visible only on screen) -->
    <div class="pdf-instruction">
        <strong>💡 How to save this as PDF:</strong> Press <kbd>Ctrl+P</kbd> (Windows) or <kbd>Cmd+P</kbd> (Mac), then choose "Save as PDF" as destination.
    </div>

    <!-- Professional Header Section -->
    <table class="pdf-header">
        <tr>
            <!-- Logo Section (Left) -->
            <td class="logo-section">
                                    <div class="default-logo">
                        <div class="logo-circle">
                            WN
                        </div>
                        <div class="logo-text">
                            Werkudara Nirwana Sakti
                        </div>
                    </div>
                            </td>

            <!-- Center Title -->
            <td class="title-section">
                <h1 class="main-title">FORMULIR</h1>
                <div class="title-separator"></div>
                <h2 class="sub-title">PURCHASE REQUISITION</h2>
            </td>

            <!-- Document Info Box (Right) -->
            <td class="doc-info-box">
                <table class="doc-info-table">
                    <tr>
                        <td>No Dok</td>
                        <td>FRM.01.00.001</td>
                    </tr>
                    <tr>
                        <td>Tgl Efektif</td>
                        <td>22-Sep-25</td>
                    </tr>
                    <tr>
                        <td>Rev</td>
                        <td>00</td>
                    </tr>
                    <tr>
                        <td>Level</td>
                        <td>4</td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <!-- PR Number and Basic Info -->
    <div class="pr-info-section">
        <div class="pr-number-line">
            No. PR.WNS/202509/003
        </div>
        
        <div class="basic-info-grid">
            <!-- Left Column -->
            <div class="info-column left-column">
                    <div class="info-row">
                        <span class="info-label">Created by</span>
                        <span class="info-colon">:</span>
                        <span class="info-value">Pramuji Arif Yulianto</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Department of PR</span>
                        <span class="info-colon">:</span>
                        <span class="info-value">BAS</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Request No.</span>
                        <span class="info-colon">:</span>
                        <span class="info-value">1</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Date of Request</span>
                        <span class="info-colon">:</span>
                        <span class="info-value">26-Sep-25</span>
                    </div>
            </div>

            <!-- Right Column -->
            <div class="info-column right-column">
                    <div class="info-row">
                        <span class="info-label">Used for</span>
                        <span class="info-colon">:</span>
                        <span class="info-value wide">Dolore iste quia et in facere optio excepturi laboriosam autem id soluta atque vero provident et iusto</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Designated Date</span>
                        <span class="info-colon">:</span>
                        <span class="info-value">N/A</span>
                    </div>
            </div>
        </div>
    </div>

    <!-- Items Table -->
    <div class="items-section">
        <table class="items-table">
            <thead>
                <tr class="table-header">
                    <th class="col-no">No</th>
                    <th class="col-item">ITEM NAME</th>
                    <th class="col-brand">BRAND NAME</th>
                    <th class="col-description">ITEM DESCRIPTION/ SPECIFICATION</th>
                    <th class="col-supplier">SUPPLIER NAME</th>
                    <th class="col-qty">QT</th>
                    <th class="col-unit">UN</th>
                    <th class="col-price">UNIT PRICE</th>
                    <th class="col-cr">CR</th>
                    <th class="col-total">TOTAL PRICE</th>
                    <th class="col-remark">REMARK</th>
                </tr>
            </thead>
            <tbody>
                                <tr class="row-even">
                    <td class="text-center">1</td>
                    <td>Quia minim cupidatat quis elit et beatae nisi culpa sapiente fugiat velit delectus ut</td>
                    <td>Voluptas fuga Qui lorem asperiores qui est eiusmod voluptate ratione consequat Do tenetur autem maiores sed</td>
                    <td>Consectetur porro nulla rerum perferendis sit mollitia tempora exercitationem</td>
                    <td>Perspiciatis voluptas proident animi eos nisi corrupti enim debitis perferendis voluptate impedit lorem facere ducimus</td>
                    <td class="text-center">17</td>
                    <td class="text-center">pcs</td>
                    <td class="text-right">0</td>
                    <td class="text-center">IDR</td>
                    <td class="text-right">0</td>
                    <td>-</td>
                </tr>
                                
                <!-- Total Row -->
                <tr class="total-row">
                    <td colspan="9" class="total-label"><strong>Total Amount:</strong></td>
                    <td class="text-right total-amount"><strong>0</strong></td>
                    <td>&nbsp;</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Modern Approval Section using Flexbox -->
    <div class="approval-section">
        
        <div class="approval-container">
            <!-- Created by Section -->
            <div class="approval-box">
                <div class="approval-title">Created by</div>

                                <div class="qr-code-container">
                    <img src="data:image/svg+xml;base64," alt="QR Code" style="width: 50px; height: 50px;">
                </div>
                
                <div class="approver-info">
                    <div class="approver-name">Pramuji Arif Yulianto</div>
                    <div class="approver-dept">BAS</div>
                </div>
            </div>

            <!-- Acknowledged by Section -->
            <div class="approval-box">
                <div class="approval-title">Acknowledged by</div>

                
                                    <div class="qr-code-container empty">&nbsp;</div>
                
                <div class="approver-info">
                                            <div class="approver-name">Hanung Sastriya</div>
                        <div class="approver-dept">BAS</div>
                                    </div>
            </div>

            <!-- Approved by Section 1 -->
            <div class="approval-box">
                <div class="approval-title">Approved by</div>

                
                                    <div class="qr-code-container empty">&nbsp;</div>
                
                <div class="approver-info">
                                            <div class="approver-name">Fadli Fahmi Ali</div>
                        <div class="approver-dept">CEO</div>
                                    </div>
            </div>

            <!-- Approved by Section 2 -->
            <div class="approval-box">
                <div class="approval-title">Approved by</div>

                
                                    <div class="qr-code-container empty">&nbsp;</div>
                
                <div class="approver-info">
                                            <div class="approver-name">Super Admin</div>
                        <div class="approver-dept">SYSADMIN</div>
                                    </div>
            </div>

            <!-- Approved by Section 3 (Last - Right Aligned) -->
            <div class="approval-box last-approval">
                <div class="approval-title">Approved by</div>

                
                                    <div class="qr-code-container empty">&nbsp;</div>
                
                <div class="approver-info">
                                            <div class="approver-name">Yulia Mekar Rini</div>
                        <div class="approver-dept">BAS</div>
                                    </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="pdf-footer">
        <p>This document was generated on 26 September 2025, 07:14 | Purchase Request System v1.0</p>
    </div>
